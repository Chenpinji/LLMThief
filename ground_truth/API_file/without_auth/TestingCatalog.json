{
  "openapi": "3.1.0",
  "info": {
    "title": "TestingCatalog API",
    "version": "1.0.0",
    "description": "This API is used to fetch various RSS feeds and the sitemap from TestingCatalog, including content related to ChatGPT, Microsoft Copilot, Bard, and more."
  },
  "servers": [
    {
      "url": "https://www.testingcatalog.com",
      "description": "TestingCatalog Main Server"
    }
  ],
  "paths": {
    "/rss": {
      "get": {
        "operationId": "getGeneralRssFeed",
        "summary": "Fetches a general RSS feed.",
        "x-openai-isConsequential": false,
        "responses": {
          "200": {
            "description": "A successful response"
          }
        }
      }
    },
    "/tag/chatgpt/rss": {

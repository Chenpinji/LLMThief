  "paths": {
    "/api/gpt/createGraphDiagram": {
      "post": {
        "summary": "Create graph diagram",
        "operationId": "CreateGraph",
        "x-openai-isConsequential": false,
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "diagramString": {
                    "type": "string",
                    "description": "The string for the chart rendering"
                  },
                  "title": {
                    "type": "string",
                    "description": "The name of the document in which the diagram will be placed"
                  },
                  "diagramColor": {
                    "type": "string",
                    "default": "rainbow"
                  },
                  "drawStyle": {
                    "type": "string",
                    "enum": [
                      "sketch",
                      "strict",
                      "code"
                    ]
                  }
                },
                "required": [
                  "diagramString",
                  "title",
                  "diagramColor"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Diagram successfully rendered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "interpretingTheAPIResponse": {
                      "type": "string",
                      "description": "How to reply to the user"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Error while rendering the diagram",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errorMessage": {
                      "type": "string"
                    },
                    "diagramTypeGuides": {
                      "type": "string",
                      "description": "look at these guides related to the current chart type, and try to fix the error"
                    }
                  },
                  "required": [
                    "errorMessage",
                    "diagramTypeGuides"
                  ]
                }
              }
            }
          }
        }
      }
    },

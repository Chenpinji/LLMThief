{
  "openapi": "3.1.0",
  "info": {
    "title": "Algorum API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://api.algorum.in",
      "description": "Production server (uses live data)"
    }
  ],
  "paths": {
    "/StockAnalysis/stock/symbols": {
      "get": {
        "operationId": "getStockSymbolIndustry",
        "tags": [
          "StockAnalysis"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StockSymbol"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StockSymbol"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StockSymbol"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/StockAnalysis/indicator/names": {
      "get": {
        "operationId": "getIndicatorNames",
        "tags": [
          "StockAnalysis"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorDetails"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorDetails"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorDetails"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/StockAnalysis/indicator/values": {
      "post": {
        "operationId": "getMultipleIndicatorsSymbolsValues",
        "tags": [
          "StockAnalysis"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MultiSymbolIndicatorRequests"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/MultiSymbolIndicatorRequests"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/MultiSymbolIndicatorRequests"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorResult"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorResult"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IndicatorResult"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AlgoRiskProfile": {
        "enum": [
          "Low",
          "Medium",
          "High"
        ],
        "type": "string"
      },
      "CandlePeriod": {
        "enum": [
          "Second",
          "Minute",
          "Day"
        ],
        "type": "string"
      },
      "Condition": {
        "enum": [
          "GreaterThan",
          "GreaterThanOrEqual",
          "LessThan",
          "LessThanOrEqual",
          "Equal",
          "NotEqual"
        ],
        "type": "string"
      },
      "MultiSymbolIndicatorRequest": {
        "type": "object",
        "properties": {
          "indicator": {
            "type": "string",
            "nullable": true
          },
          "customPeriod": {
            "type": "boolean"
          },
          "candlePeriod": {
            "$ref": "#/components/schemas/CandlePeriod"
          },
          "periodSpan": {
            "type": "integer",
            "format": "int32"
          },
          "candles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ohlcv"
            },
            "nullable": true
          },
          "paramMap": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "format": "double",
              "nullable": true
            },
            "nullable": true
          },
          "symbols": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "uptoDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MultiSymbolIndicatorRequests": {
        "type": "object",
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MultiSymbolIndicatorRequest"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "IndicatorData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true
          },
          "userId": {
            "type": "string",
            "nullable": true
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "result": {
            "type": "number",
            "format": "double"
          },
          "candles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ohlcv"
            },
            "nullable": true
          },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "nullable": true
          },
          "lineItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LineItem"
            },
            "nullable": true
          },
          "candleResult": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "number",
                "format": "double"
              },
              "nullable": true
            },
            "nullable": true
          },
          "symbol": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "IndicatorDetails": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "indicator": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "IndicatorResult": {
        "type": "object",
        "properties": {
          "indicator": {
            "type": "string",
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "paramMap": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "nullable": true
          },
          "hasResultMap": {
            "type": "boolean"
          },
          "resultMap": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "format": "double",
              "nullable": true
            },
            "nullable": true
          },
          "result": {
            "type": "number",
            "format": "double"
          },
          "candles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Ohlcv"
            },
            "nullable": true
          },
          "indicatorDataId": {
            "type": "string",
            "nullable": true
          },
          "candleResult": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": {
                "type": "number",
                "format": "double"
              },
              "nullable": true
            },
            "nullable": true
          },
          "symbol": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LineItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "color": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Ohlcv": {
        "type": "object",
        "properties": {
          "dateId": {
            "type": "string",
            "nullable": true
          },
          "open": {
            "type": "number",
            "format": "double"
          },
          "high": {
            "type": "number",
            "format": "double"
          },
          "low": {
            "type": "number",
            "format": "double"
          },
          "close": {
            "type": "number",
            "format": "double"
          },
          "volume": {
            "type": "number",
            "format": "double"
          },
          "dateTime": {
            "type": "string",
            "format": "date-time"
          },
          "dateTimeNormal": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "OrderType": {
        "enum": [
          "Market",
          "Limit"
        ],
        "type": "string"
      },
      "StockSymbol": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "industry": {
            "type": "string",
            "nullable": true
          },
          "symbol": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}
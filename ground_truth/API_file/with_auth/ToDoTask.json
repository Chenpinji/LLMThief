        "responses": {
          "200": {
            "description": "The task details.",
            "content": {
              "application/json": {
                "example": {
                  "id": 1,
                  "content": "Buy groceries",
                  "project_id": 1
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update task",
        "description": "Update the details of a specific task.",
        "operationId": "updateTask",
        "x-openai-isConsequential": true,
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "content": "Updated Task"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated task details.",
            "content": {
              "application/json": {
                "example": {
                  "id": 1,
                  "content": "Updated Task",
                  "project_id": 1
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete task",
        "description": "Delete a specific task.",
        "operationId": "deleteTask",
        "x-openai-isConsequential": true,
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Task successfully deleted."
          }
        }
      }
    },
    "/labels": {
      "get": {
        "summary": "List labels",
